# Copy this file to .env and fill in real values. Never commit .env.

# FileMaker — same shared login already used by MeetingPrepTool's .fm_creds
FM_HOST=https://fms14.filemakerstudio.com.au
FM_DATABASE=IRD Subscribing Contacts
FM_USER=
FM_PASSWORD=

# MCP server
# Bind to localhost only — Caddy is the only thing that should talk to this
# process directly; it terminates TLS and proxies to here (see deploy/).
MCP_HOST=127.0.0.1
MCP_PORT=8420
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
MCP_BEARER_TOKEN=
# Comma-separated public hostname(s) this server is reached through (via the
# reverse proxy). Required for the MCP SDK's DNS-rebinding protection to
# accept requests — without it, every proxied request is rejected with
# "Invalid Host header".
MCP_PUBLIC_HOSTNAMES=fm-crm-mcp.74.208.125.60.sslip.io
